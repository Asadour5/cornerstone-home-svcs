---
import logo from '../../assets/img/goliath_logo.png' 
export interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'h-5 w-auto',
  md: 'h-6 w-auto',
  lg: 'h-20 w-auto'
};

---
<img
src={logo.src}
alt="Goliath Home Service"
class:list={[sizeClasses[size], className]}
/>