---
import Container from '../shared/Container.astro';
import Logo from '../shared/Logo.astro';
import Icon from '../shared/Icon.astro';
---
<footer class="border-t border-slate-200 dark:border-slate-800 bg-background-light dark:bg-background-dark py-12">
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 text-slate-900 dark:text-slate-100 mb-6">
          <Logo size="sm" />
          <span class="font-bold uppercase tracking-tight">Cornerstone Home Service</span>
        </div>
        <p class="text-slate-600 dark:text-slate-300 text-sm max-w-sm font-light leading-relaxed">
          Serving San Antonio and Boerne families with honest handyman work and quality home improvement. Insured, HIC licensed, and built on a foundation of integrity.
        </p>
      </div>

      <div>
        <h2 class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6">Connect</h2>
        <ul class="space-y-3">
          <li>
            <a href="https://www.instagram.com/cornerstonehomeservicellc" class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-instagram" size={16} />
              Instagram
            </a>
          </li>
          <li>
            <a href="https://wa.me/12109681822" class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-whatsapp" size={16} />
              WhatsApp
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6">Contact</h2>
        <p class="text-slate-600 dark:text-slate-300 text-sm font-light mb-1">Email:</p>
        <p class="text-slate-900 dark:text-slate-100 text-sm font-medium mb-4 flex items-center gap-2">
          <Icon name="mail" size={16} class="text-primary" />
          nick@cshomeservice.biz
        </p>
        <p class="text-slate-600 dark:text-slate-300 text-sm font-light mb-1">Phone:</p>
        <p class="text-slate-900 dark:text-slate-100 text-sm font-medium flex items-center gap-2">
          <Icon name="phone" size={16} class="text-primary" />
          (210) 968-1822
        </p>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium">
          © 2026 Cornerstone Home Service LLC. All Rights Reserved.
        </p>
<!--        <p class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium">
          Designed by <a href="https://ec2-18-116-70-40.us-east-2.compute.amazonaws.com/hw7/" class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors">Matthew McCabe</a>
        </p>-->
      </div>
      <div class="flex gap-8">
        <a href="/privacy" class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
          Terms
        </a>
      </div>
    </div>
  </Container>
</footer>

