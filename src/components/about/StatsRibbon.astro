---
import Container from '../shared/Container.astro';

const stats = [
  { value: "10+", label: "Years Experience" },
  { value: "240", label: "Projects Built" },
  { value: "100%", label: "Insured & Licensed" },
  { value: "5★", label: "Client Satisfaction" }
];
---

<section class="border-y border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
  <Container>
    <div class="py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center md:text-left">
          <p class="text-3xl font-black text-primary">{stat.value}</p>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">{stat.label}</p>
        </div>
      ))}
    </div>
  </Container>
</section>