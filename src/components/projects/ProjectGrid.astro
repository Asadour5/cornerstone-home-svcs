---
import Container from '../shared/Container.astro';
import ProjectCard from './ProjectCard.astro';
import project1Image from '../../assets/img/projects-page-img-01.jpg';
import project2Image from '../../assets/img/projects-page-img-02.jpg';
import project3Image from '../../assets/img/projects-page-img-03.jpg';
import project4Image from '../../assets/img/projects-page-img-04.jpg';
import project5Image from '../../assets/img/projects-page-img-05.jpg';
import project6Image from '../../assets/img/projects-page-img-06.jpg';

const projects = [
  {
    title: "Bathroom Makeover",
    category: "Bathroom Refresh",
    location: "San Antonio, TX",
    year: "2024",
    image: project1Image,
    alt: "Refreshed bathroom with new vanity, mirror, and fixtures"
  },
  {
    title: "New Playset Assembly",
    category: "Backyards",
    location: "Boerne, TX",
    year: "2024",
    image: project2Image,
    alt: "Backyard revamp"
  },
  {
    title: "Drywall Water Damage Repair",
    category: "Drywall & Patching",
    location: "San Antonio, TX",
    year: "2023",
    image: project3Image,
    alt: "Seamless drywall patch and texture match after water damage"
  },
  {
    title: "End Table Assembly",
    category: "Room Refresh",
    location: "Boerne, TX",
    year: "2024",
    image: project4Image,
    alt: "Bedroom refresh with new paint, trim, and ceiling fan install"
  },
  {
    title: "Rental Unit Turnover",
    category: "Rental Turnover",
    location: "San Antonio, TX",
    year: "2023",
    image: project5Image,
    alt: "Rental unit repainted, patched, and fixtures replaced for new tenants"
  },
  {
    title: "Gutter Cleanup",
    category: "Exterior & Gutters",
    location: "Boerne, TX",
    year: "2024",
    image: project6Image,
    alt: "Fence slats replaced and stained, gutters cleaned and cleared"
  }
];
---

<Container>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project) => (
      <ProjectCard
        title={project.title}
        category={project.category}
        location={project.location}
        year={project.year}
        image={project.image}
        alt={project.alt}
      />
    ))}
  </div>
</Container>