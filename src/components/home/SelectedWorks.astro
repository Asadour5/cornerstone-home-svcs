---
import Container from '../shared/Container.astro';
import ProjectCard from './ProjectCard.astro';
import Icon from '../shared/Icon.astro';
import project1Image from '../../assets/img/home-page-img-03.jpg';
import project2Image from '../../assets/img/home-page-img-04.jpg';
import project3Image from '../../assets/img/home-page-img-05.jpg';
import project4Image from '../../assets/img/home-page-img-06.jpg';

const projects = [
  {
    title: "Master Bath Refresh",
    category: "Bathroom Refresh",
    year: "2024",
    image: project1Image,
    alt: "Refreshed bathroom with new vanity, mirror, and updated fixtures"
  },
  {
    title: "Living Room Repaint",
    category: "Interior Painting",
    year: "2024",
    image: project2Image,
    alt: "Freshly painted living room with clean trim and neutral tones"
  },
  {
    title: "Plumbing & Fixture Work",
    category: "Fixtures & Plumbing",
    year: "2023",
    image: project3Image,
    alt: "Technician working on pipe fittings and brass valve connections"
  },
  {
    title: "Rental Unit Makeover",
    category: "Rental Makeover",
    year: "2024",
    image: project4Image,
    alt: "Rental unit repainted, patched, and fixtures replaced for new tenants"
  }
];
---
<section class="py-24 md:py-32">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-xl">
        <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block">Our Work</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter uppercase leading-none">Recent Projects</h2>
      </div>
      <a href="/projects" class="group flex items-center gap-2 text-sm font-bold uppercase tracking-widest border-b-2 border-primary pb-1">
        All Projects
        <Icon name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {projects.map((project, index) => (
        <ProjectCard
          title={project.title}
          category={project.category}
          year={project.year}
          image={project.image}
          alt={project.alt}
          index={index}
        />
      ))}
    </div>
  </Container>
</section>