---
import Container from '../shared/Container.astro';
import Button from '../shared/Button.astro';
import Icon from '../shared/Icon.astro';
import { Image } from 'astro:assets';
import approachImage from '../../assets/img/home-page-img-02.jpg';
---
<section class="bg-slate-100 dark:bg-background-dark/50 py-24 md:py-40">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-32 items-center">
      <!-- Image -->
      <div class="order-2 lg:order-1">
        <div class="relative overflow-hidden rounded group">
          <Image
            src={approachImage}
            alt="Handyman completing a home improvement project"
            class="w-full aspect-square object-cover grayscale group-hover:grayscale-0 transition-all duration-1000"
            loading="lazy"
            decoding="async"
            layout="constrained"
            width={800}
            height={800}
            format="webp"
            fit="cover"
            widths={[400, 600, 800, 1024]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
          />
          <div class="absolute inset-0 border-[20px] border-white/10 pointer-events-none" />
        </div>
      </div>
      <!-- Content -->
      <div class="order-1 lg:order-2">
        <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-6 block">Our Approach</span>
        <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase leading-[0.9] mb-10">
          No Shortcuts.<br />No Excuses.
        </h1>
        <div class="space-y-8 max-w-lg">
          <p class="text-lg md:text-xl text-slate-700 dark:text-slate-300 leading-relaxed font-light">
            We believe your home deserves honest work done right the first time. Every repair, every install, and every refresh is completed with the same care we give our own homes.
          </p>
          <div class="grid grid-cols-2 gap-6 pt-6">
            <div class="flex flex-col gap-2">
              <Icon name="tool" size={32} class="text-primary" />
              <span class="font-bold uppercase tracking-widest text-sm text-slate-700 dark:text-slate-200 block">
                Craftsmanship
              </span>
              <p class="text-xs text-slate-600 dark:text-slate-300 uppercase tracking-wider">
                Quality work on every job, big or small.
              </p>
            </div>
            <div class="flex flex-col gap-2">
              <Icon name="heart" size={32} class="text-primary" />
              <span class="font-bold uppercase tracking-widest text-sm text-slate-700 dark:text-slate-200 block">
                Integrity
              </span>
              <p class="text-xs text-slate-600 dark:text-slate-300 uppercase tracking-wider">
                Honest pricing, no surprises, no shortcuts.
              </p>
            </div>
            <div class="flex flex-col gap-2">
              <Icon name="shield-check" size={32} class="text-primary" />
              <span class="font-bold uppercase tracking-widest text-sm text-slate-700 dark:text-slate-200 block">
                Licensed & Insured
              </span>
              <p class="text-xs text-slate-600 dark:text-slate-300 uppercase tracking-wider">
                HIC licensed, fully insured for your peace of mind.
              </p>
            </div>
            <div class="flex flex-col gap-2">
              <Icon name="clock" size={32} class="text-primary" />
              <span class="font-bold uppercase tracking-widest text-sm text-slate-700 dark:text-slate-200 block">
                Reliability
              </span>
              <p class="text-xs text-slate-600 dark:text-slate-300 uppercase tracking-wider">
                We show up when we say we will, every time.
              </p>
            </div>
          </div>
          <Button href="/about" variant="outline" size="lg">Our Story</Button>
        </div>
      </div>
    </div>
  </Container>
</section>