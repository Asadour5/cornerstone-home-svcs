---
import Container from '../shared/Container.astro';
import Icon from '../shared/Icon.astro';
const currentPath = Astro.url.pathname;
---
<header class="fixed top-0 w-full z-50 bg-white/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-slate-100 dark:border-slate-800">
  <Container class="h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group cursor-pointer">
      <div class="text-primary">
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 48 48">
          <path d="M24 0.757355L47.2426 24L24 47.2426L0.757355 24L24 0.757355ZM21 35.7574V12.2426L9.24264 24L21 35.7574Z" />
        </svg>
      </div>
      <h1 class="text-xl font-black tracking-tighter uppercase">Cornerstone</h1>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-10">
      <a href="/" class:list={["text-sm font-semibold transition-colors", currentPath === '/' ? "text-primary" : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"]}>
        Home
      </a>
      <a href="/projects" class:list={["text-sm font-semibold transition-colors", currentPath === '/projects' || currentPath.startsWith('/projects/') ? "text-primary" : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"]}>
        Projects
      </a>
      <a href="/about" class:list={["text-sm font-semibold transition-colors", currentPath === '/about' ? "text-primary" : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"]}>
        About
      </a>
    </nav>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-4">
      <a href="/contact" class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded text-sm font-bold uppercase tracking-wider transition-all flex items-center gap-2">
        <Icon name="send" size={16} />
        <span>Inquire</span>
      </a>
      <button id="menu-toggle" class="md:hidden p-2 text-slate-600 dark:text-slate-400" aria-label="Open menu">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </Container>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 dark:border-slate-800 bg-white/95 dark:bg-background-dark/95 backdrop-blur-md">
    <nav class="flex flex-col px-6 py-4 gap-1">
      <a href="/" class:list={["py-3 text-sm font-semibold transition-colors border-b border-slate-100 dark:border-slate-800", currentPath === '/' ? "text-primary" : "text-slate-600 dark:text-slate-400"]}>
        Home
      </a>
      <a href="/projects" class:list={["py-3 text-sm font-semibold transition-colors border-b border-slate-100 dark:border-slate-800", currentPath === '/projects' ? "text-primary" : "text-slate-600 dark:text-slate-400"]}>
        Projects
      </a>
      <a href="/about" class:list={["py-3 text-sm font-semibold transition-colors border-b border-slate-100 dark:border-slate-800", currentPath === '/about' ? "text-primary" : "text-slate-600 dark:text-slate-400"]}>
        About
      </a>
      <a href="/contact" class="py-3 text-sm font-semibold text-primary">
        Contact
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // close menu on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>